# AI Configuration
# Set AI_PROVIDER to "anthropic" (default) or "openai"
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_MODEL=claude-opus-4-6
AI_MAX_TOKENS_PER_REQUEST=4000
AI_MONTHLY_WARNING_THRESHOLD_USD=10.00

# Claude Code Integration
CLAUDE_CODE_ENABLED=true
CLAUDE_CODE_SKILLS_PATH=

# Application
APP_PORT=8000
FRONTEND_PORT=3000
DATA_DIR=./data
BLOB_DIR=./data/blobs
FILES_DIR=./data/files
# CHROMA_DIR=./data/chroma   # optional override; defaults to DATA_DIR/chroma
